{"entries":[{"timestamp":1772547298712,"editorVersion":"4.0.10","changes":[{"type":"edited","filename":"main.blocks","patch":[{"start1":0,"length1":2848,"diffs":[[1,"<xml xmlns=\"http://www.w3.org/1999/xhtml\">\n  <variables></variables>\n  <block type=\"pxt-on-start\" x=\"0\" y=\"0\"></block>\n</xml>"]]}]},{"type":"edited","filename":"main.ts","patch":[{"start1":0,"length1":1336,"diffs":[[1," "]]}]},{"type":"edited","filename":"pxt.json","patch":[{"start1":177,"length1":92,"diffs":[[1,"        \"assets.json\"\n"]]},{"start1":206,"length1":31,"diffs":[[1,"    \"additionalFilePaths\": []\n"]]}]},{"type":"added","filename":"debug.ts","value":"//% color=\"#cf0000\" icon=\"\\uf121\" block=\"Debugger Pro\"\nnamespace Debugger {\n    let debugEnabled = false;\n\n    //% block=\"set collision debugger %on\"\n    //% on.shadow=\"toggleOnOff\"\n    export function setDebug(on: boolean) {\n        debugEnabled = on;\n    }\n\n    scene.createRenderable(100, function (target: Image, camera: scene.Camera) {\n        if (!debugEnabled) return;\n\n        const scene = game.currentScene();\n        const allSprites = scene.allSprites;\n\n        // --- 6. TILEMAP DEBUGGER (Muros invisibles) ---\n        const tm = scene.tileMap;\n        if (tm) {\n            const startCol = Math.max(0, Math.floor(camera.drawOffsetX / tm.scale));\n            const endCol = Math.min(tm.areaWidth() / tm.scale, startCol + 11); // 160px / 16px approx\n            const startRow = Math.max(0, Math.floor(camera.drawOffsetY / tm.scale));\n            const endRow = Math.min(tm.areaHeight() / tm.scale, startRow + 9);\n\n            for (let c = startCol; c <= endCol; c++) {\n                for (let r = startRow; r <= endRow; r++) {\n                    if (tm.isObstacle(c, r)) {\n                        const tx = (c * tm.scale) - camera.drawOffsetX;\n                        const ty = (r * tm.scale) - camera.drawOffsetY;\n                        // Dibujar borde amarillo en paredes\n                        target.drawRect(tx, ty, tm.scale, tm.scale, 5);\n                    }\n                }\n            }\n        }\n\n        // --- SPRITE DEBUGGER (1, 2, 3) ---\n        for (let item of allSprites) {\n            if (item instanceof Sprite) {\n                const s = item as Sprite;\n                if (s.flags & sprites.Flag.Destroyed) continue;\n\n                const ox = s.left - camera.drawOffsetX;\n                const oy = s.top - camera.drawOffsetY;\n                const cx = s.x - camera.drawOffsetX;\n                const cy = s.y - camera.drawOffsetY;\n\n                // --- 2. DYNAMIC COLORS (Estado de colisión) ---\n                let color = 2; // Rojo (Normal)\n                if (s.isHittingTile(CollisionDirection.Bottom)) color = 7; // Verde (Suelo)\n                if (s.isHittingTile(CollisionDirection.Top | CollisionDirection.Left | CollisionDirection.Right)) color = 4; // Naranja (Pared/Techo)\n\n                // Dibujar Hitbox\n                target.drawRect(ox, oy, s.width, s.height, color);\n\n                // --- 1. DIRECTION VECTORS (Velocidad) ---\n                if (Math.abs(s.vx) > 1 || Math.abs(s.vy) > 1) {\n                    // Línea blanca que muestra la dirección del movimiento\n                    target.drawLine(cx, cy, cx + (s.vx / 5), cy + (s.vy / 5), 1);\n                }\n\n                // --- 3. LABELS (Etiquetas de datos) ---\n                // Muestra el Kind y la posición Y (útil para saltos)\n                target.print(s.kind().toString(), ox, oy - 10, 5);\n                target.print(\"y:\" + Math.round(s.y), ox, oy + s.height + 2, 9);\n\n                // Punto de anclaje\n                target.setPixel(cx, cy, 5);\n            }\n        }\n    });\n}\n"},{"type":"added","filename":"tilemap.g.jres","value":"{\n    \"transparency16\": {\n        \"data\": \"hwQQABAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA